---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/navigation/Navbar.astro";
import Footer from "@/components/navigation/Footer.astro";
---

<Layout
    title="Privacy Policy | Store'nU"
    description="Privacy Policy and Personal Data processing for Techveda ApS."
>
    <Navbar />

    <main class="mt-24 mb-20 px-4">
        <div class="max-w-4xl mx-auto">
            <div
                class="bg-secondary-background border-4 border-border p-8 md:p-12 shadow-shadow rounded-base"
            >
                <h1 class="text-4xl md:text-6xl font-heading mb-4 uppercase">
                    Privacy Policy
                </h1>
                <p class="text-xl font-bold mb-8 text-zinc-600">
                    Last updated on 23/Feb/2026
                </p>

                <div
                    class="prose prose-zinc prose-invert max-w-none space-y-8 text-lg font-medium leading-relaxed"
                >
                    <section class="space-y-4">
                        <p>
                            Here you can read about our processing of your
                            personal data and your rights in connection with the
                            use of products and services from <span
                                class="text-main font-bold italic"
                                >Techveda ApS</span
                            >, hereinafter referred to as we or us.
                        </p>
                        <p>
                            We process the information you provide to us or that
                            we collect about you in accordance with applicable
                            regulations. We intend that your information will be
                            processed with respect for the confidentiality of
                            the information and for your privacy.
                        </p>
                        <p>
                            Techveda ApS, CVR: 43811606, is the data controller
                            for the personal data that the company collects in
                            processing matters about our customers and their
                            employees.
                        </p>
                        <p>
                            This privacy policy applies to all business
                            processes and to all websites, domains, mobile
                            solutions, cloud services under the ownership of
                            Techveda ApS.
                        </p>
                        <p>
                            Service-specific terms can be found in our General
                            Terms of Sale and Service, Data Processing Agreement
                            or similar information for the specific service in
                            question.
                        </p>
                    </section>

                    <section
                        class="bg-main/10 border-2 border-border p-6 rounded-base"
                    >
                        <h2 class="text-2xl font-heading uppercase mb-4">
                            Contact information:
                        </h2>
                        <address class="not-italic space-y-1 font-bold">
                            <p>Techveda ApS</p>
                            <p>Gersonsvej 51 1</p>
                            <p>2900 Hellerup</p>
                            <p>Phone +45 60556036</p>
                            <p>
                                E-mail: <a
                                    href="mailto:data@techveda.dk"
                                    class="underline decoration-2 decoration-main hover:text-main"
                                    >data@techveda.dk</a
                                >
                            </p>
                            <p>CVR: 43811606</p>
                        </address>
                    </section>

                    <section class="space-y-4">
                        <h2 class="text-3xl font-heading uppercase">
                            Services covered by this policy
                        </h2>
                        <p>
                            This policy applies to all individuals, customers,
                            companies/organizations who interact with Techveda
                            ApS, or to you who interact with us via our website
                            or SOME channels.
                        </p>
                    </section>

                    <section class="space-y-4">
                        <h2 class="text-3xl font-heading uppercase">
                            Acceptance of this policy
                        </h2>
                        <p>
                            If you or the company you represent uses our
                            products and services, or interacts on our websites,
                            you accept this privacy policy and our cookie
                            policy.
                        </p>
                    </section>

                    <section class="space-y-4">
                        <h2
                            class="text-3xl font-heading uppercase border-b-4 border-main pb-2 inline-block"
                        >
                            Collection of personal data
                        </h2>

                        <div class="mt-4 space-y-6">
                            <div>
                                <h3
                                    class="text-xl font-heading uppercase text-main mb-2"
                                >
                                    Information you provide to us
                                </h3>
                                <p>
                                    We collect personal information in the form
                                    of name, email address, organization /
                                    company and telephone number (contact
                                    information) when you register as a customer
                                    with us, contact us via our website,
                                    Facebook page, LinkedIn page or let one of
                                    our employees register you as a customer.
                                </p>
                                <p class="mt-2">
                                    We may use your information, including your
                                    email address and telephone number, to
                                    contact you regarding agreements made,
                                    inform you about our services and any new
                                    features that may be of interest to you.
                                </p>
                                <p class="mt-2">
                                    Personal information is all kinds of
                                    information that can be attributed to you to
                                    some extent. When you use our website, we
                                    collect and process a number of such
                                    information. This happens, for example, by
                                    general access to content, if you sign up
                                    for our newsletter, “Like” our social media
                                    pages or posts on social media, fill in
                                    information in fields “Be contacted by us”,
                                    or contact us via a contact form on our
                                    websites or by telephone.
                                </p>
                                <p class="mt-2 italic">
                                    We only use your email etc. for marketing if
                                    we have received your express prior consent
                                    to do so.
                                </p>
                            </div>

                            <div>
                                <h3
                                    class="text-xl font-heading uppercase text-main mb-2"
                                >
                                    Use of services
                                </h3>
                                <p>
                                    We log usage data when you visit or
                                    otherwise use our services, including our
                                    websites and services, such as when you view
                                    or click on a document or perform a search.
                                    We use logins, cookies, device information,
                                    and Internet Protocol addresses (“IP
                                    addresses”) to identify you and log your
                                    usage.
                                </p>
                                <p class="mt-2">
                                    We do not collect personal information about
                                    you from third parties. However, we do
                                    collect information through our cookies.
                                    Read more about our cookie policy.
                                </p>
                                <p class="mt-2">
                                    Our Services are dynamic, and we frequently
                                    update our Services with new features that
                                    may require the collection of new
                                    information. If we collect new personal
                                    information or use your personal information
                                    for other purposes, we will notify you and,
                                    to the extent applicable, we will also make
                                    changes to this Privacy Policy.
                                </p>
                            </div>
                        </div>
                    </section>

                    <section class="space-y-4">
                        <h2 class="text-3xl font-heading uppercase">
                            Use of personal data
                        </h2>
                        <p>
                            We use your personal information to provide, support
                            and develop our services, to fulfill the contractual
                            relationship we have with you or the
                            organization/company you represent.
                        </p>
                        <p>
                            Your personal data will not be disclosed to third
                            parties unless you have expressly consented to this,
                            or we believe it is required by law, or to protect
                            you, your safety and your rights.
                        </p>
                        <p>
                            We use a number of subcontractors to assist us in
                            providing our services. These subcontractors may
                            have access to your information, but only for the
                            purpose of assisting us in providing our services.
                        </p>
                        <p>
                            If you would like to know more about our
                            subcontractors, please contact us at <a
                                href="mailto:info@techveda.dk"
                                class="underline decoration-2 decoration-main hover:text-main"
                                >info@techveda.dk</a
                            >.
                        </p>
                    </section>

                    <section class="space-y-4">
                        <h2 class="text-3xl font-heading uppercase">
                            Compliance with the law
                        </h2>
                        <p>
                            We may share your personal data with public and
                            judicial authorities if Danish and EU law requires
                            us to do so. For example, if we believe it is
                            necessary to comply with the EU General Data
                            Protection Regulation or if we become aware that you
                            are using our services to break the law.
                        </p>
                    </section>

                    <section class="space-y-4">
                        <h2 class="text-3xl font-heading uppercase">
                            Storage of personal data
                        </h2>
                        <p>
                            We store your personal data as long as we have an
                            active contractual relationship with you/your
                            organization.
                        </p>
                        <p>
                            When the contractual relationship has ended, we will
                            store your personal data for as long as we are
                            obliged to do so under applicable legislation with
                            longer validity, including, for example, the Danish
                            Accounting Act.
                        </p>
                    </section>

                    <section class="space-y-4">
                        <h2 class="text-3xl font-heading uppercase">
                            Security
                        </h2>
                        <p>
                            We have taken technical and organizational security
                            measures to protect your personal data against loss,
                            misuse, disclosure or unauthorized access. Our
                            security measures are continuously reviewed in line
                            with technical developments.
                        </p>
                        <p>
                            Our software and data are only hosted with cloud
                            providers within the EU when this is necessary to
                            comply with GDPR.
                        </p>
                    </section>

                    <section class="space-y-4">
                        <h2 class="text-3xl font-heading uppercase">
                            Your rights
                        </h2>
                        <p>
                            Individuals whose information we process (data
                            subjects) have a number of rights under the General
                            Data Protection Regulation. If you would like to
                            exercise your rights, please contact us.
                        </p>
                        <p>
                            Requests regarding your rights that are manifestly
                            unfounded or excessive – especially because they are
                            repeated – may be rejected, or the Company may
                            charge a reasonable fee for responding to the
                            request.
                        </p>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
                            <div
                                class="border-2 border-border p-4 rounded-base bg-main/5"
                            >
                                <h3 class="font-heading uppercase mb-2">
                                    The right to access
                                </h3>
                                <p class="text-sm italic">
                                    You have the right to access the personal
                                    data that we process about you, including
                                    receiving a copy of the personal data.
                                </p>
                            </div>
                            <div
                                class="border-2 border-border p-4 rounded-base bg-main/5"
                            >
                                <h3 class="font-heading uppercase mb-2">
                                    Right to rectification
                                </h3>
                                <p class="text-sm italic">
                                    You have the right to request that incorrect
                                    information about yourself be corrected or
                                    updated.
                                </p>
                            </div>
                            <div
                                class="border-2 border-border p-4 rounded-base bg-main/5"
                            >
                                <h3 class="font-heading uppercase mb-2">
                                    Right to erasure
                                </h3>
                                <p class="text-sm italic">
                                    In special cases, you have the right to have
                                    information about you deleted before our
                                    general erasure time occurs.
                                </p>
                            </div>
                            <div
                                class="border-2 border-border p-4 rounded-base bg-main/5"
                            >
                                <h3 class="font-heading uppercase mb-2">
                                    Right to restriction
                                </h3>
                                <p class="text-sm italic">
                                    In certain cases, you have the right to have
                                    the processing of your personal data
                                    restricted.
                                </p>
                            </div>
                            <div
                                class="border-2 border-border p-4 rounded-base bg-main/5"
                            >
                                <h3 class="font-heading uppercase mb-2">
                                    Right to transmission
                                </h3>
                                <p class="text-sm italic">
                                    In certain cases, you have the right to
                                    receive personal data about yourself in a
                                    machine-readable format.
                                </p>
                            </div>
                            <div
                                class="border-2 border-border p-4 rounded-base bg-main/5"
                            >
                                <h3 class="font-heading uppercase mb-2">
                                    Right to object
                                </h3>
                                <p class="text-sm italic">
                                    In certain cases, you have the right to
                                    object to otherwise lawful processing of
                                    your personal data.
                                </p>
                            </div>
                        </div>

                        <p class="mt-4">
                            You can read more about your rights in the Danish
                            Data Protection Agency's guidance on the rights of
                            data subjects at <a
                                href="https://www.datatilsynet.dk"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="underline decoration-2 decoration-main hover:text-main"
                                >www.datatilsynet.dk</a
                            >.
                        </p>
                    </section>

                    <section class="space-y-4 border-t-4 border-border pt-8">
                        <h2 class="text-3xl font-heading uppercase">
                            Complaint to the Danish Data Protection Agency
                        </h2>
                        <p>
                            You have the right to file a complaint with the
                            Danish Data Protection Agency if you are
                            dissatisfied with the way we process your personal
                            data. You can find the Data Protection Authority's
                            contact information at <a
                                href="https://www.datatilsynet.dk"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="underline decoration-2 decoration-main hover:text-main"
                                >www.datatilsynet.dk</a
                            >.
                        </p>
                    </section>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
