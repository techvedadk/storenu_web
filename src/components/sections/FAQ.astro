---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="faq" class="mx-auto max-w-2xl py-24 px-4">
    <h2 class="text-5xl font-heading text-center mb-16 uppercase">
        {t("faq.title")}
        <span class="italic underline">{t("faq.titleAccent")}</span>
    </h2>
    <div class="space-y-4">
        <details
            class="group rounded-base border-2 border-border bg-white p-6 shadow-shadow open:bg-main transition-colors"
        >
            <summary
                class="flex items-center justify-between cursor-pointer list-none font-heading text-xl uppercase"
            >
                {t("faq.q1.q")}
                <span class="transition-transform group-open:rotate-45 text-3xl"
                    >+</span
                >
            </summary>
            <div class="mt-4 font-bold text-lg">
                {t("faq.q1.a")}
            </div>
        </details>
        <details
            class="group rounded-base border-2 border-border bg-white p-6 shadow-shadow open:bg-main transition-colors"
        >
            <summary
                class="flex items-center justify-between cursor-pointer list-none font-heading text-xl uppercase"
            >
                {t("faq.q2.q")}
                <span class="transition-transform group-open:rotate-45 text-3xl"
                    >+</span
                >
            </summary>
            <div class="mt-4 font-bold text-lg">
                {t("faq.q2.a")}
            </div>
        </details>
        <details
            class="group rounded-base border-2 border-border bg-white p-6 shadow-shadow open:bg-main transition-colors"
        >
            <summary
                class="flex items-center justify-between cursor-pointer list-none font-heading text-xl uppercase"
            >
                {t("faq.q3.q")}
                <span class="transition-transform group-open:rotate-45 text-3xl"
                    >+</span
                >
            </summary>
            <div class="mt-4 font-bold text-lg">
                {t("faq.q3.a")}
            </div>
        </details>
    </div>
</section>
