---
import { Button } from "@/components/ui/button";
---

<section id="pricing" class="mx-auto max-w-7xl py-24 px-4">
    <div
        class="rounded-base border-4 border-border bg-white p-12 md:p-24 shadow-shadow text-center relative overflow-hidden"
    >
        <div
            class="absolute top-0 right-0 w-64 h-64 bg-main/10 rounded-full -mr-32 -mt-32"
        >
        </div>
        <div class="relative z-10">
            <h2
                class="text-5xl md:text-8xl font-heading uppercase leading-none mb-8 italic"
            >
                START YOUR <br />
                <span class="bg-main px-2 border-2 border-border shadow-shadow"
                    >DOMINATION.</span
                >
            </h2>
            <p class="text-xl md:text-2xl font-bold mb-12 max-w-2xl mx-auto">
                Setup takes less than 24 hours. Join the hundreds of restaurants
                already saving thousands every month.
            </p>
            <div class="flex flex-col items-center justify-center gap-6">
                <Button size="lg" className="h-20 px-16 text-2xl"
                    >I'M IN, GIVE ME 0% COMM.</Button
                >
                <span
                    class="text-sm font-bold uppercase tracking-widest text-zinc-500"
                    >NO CREDIT CARD REQUIRED. START FREE.</span
                >
            </div>
        </div>
    </div>
</section>
