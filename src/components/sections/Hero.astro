---
import { Button } from "@/components/ui/button";
import { StartStoreDialog } from "@/components/StartStoreDialog";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="mx-auto max-w-7xl pt-12 pb-24 px-6 text-center">
    <div
        class="inline-block rounded-base border-2 border-border bg-main px-4 py-1 text-xs font-heading shadow-shadow uppercase mb-8"
    >
        {t("hero.badge")}
    </div>
    <h1 class="mb-8 text-6xl font-heading leading-tight md:text-9xl">
        {t("hero.title")}
        <span
            class="bg-white px-4 border-4 border-border shadow-shadow italic lg:rotate-2 inline-block"
            >{t("hero.titleAccent")}</span
        >
    </h1>
    <p class="mx-auto mb-10 max-w-2xl text-xl font-medium md:text-2xl">
        {t("hero.description")}
        <span class="bg-main px-1">{t("hero.descriptionAccent")}</span>
    </p>
    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <StartStoreDialog client:load lang={lang}>
            <Button size="lg" className="text-xl px-12 h-16"
                >{t("hero.cta")}</Button
            >
        </StartStoreDialog>
        <Button variant="outline" size="lg" className="text-xl px-12 h-16"
            >{t("hero.demo")}</Button
        >
    </div>

    <div class="mt-20 flex justify-center">
        <div class="relative w-full max-w-5xl">
            <div
                class="rounded-base border-2 border-border bg-white p-2 shadow-shadow overflow-hidden"
            >
                <img
                    src="/hero.png"
                    alt="Dashboard Preview"
                    class="w-full object-cover transition-transform hover:scale-105 duration-700"
                />
            </div>
            <!-- Decorative elements -->
            <div
                class="absolute -left-8 -top-8 h-32 w-32 rounded-full border-2 border-border bg-main shadow-shadow md:flex items-center justify-center hidden"
            >
                <span
                    class="font-heading text-sm rotate-12 text-center leading-none uppercase"
                    >{t("hero.commissionBadge")}<br />{
                        t("hero.commissionSub")
                    }</span
                >
            </div>
            <div
                class="absolute -right-12 bottom-12 h-40 w-40 rounded-base border-2 border-border bg-white shadow-shadow md:block hidden p-4 rotate-6"
            >
                <div class="h-2 w-full bg-main mb-2"></div>
                <div class="h-2 w-2/3 bg-zinc-200 mb-2"></div>
                <div class="h-2 w-full bg-zinc-200 mb-2"></div>
                <div class="mt-4 flex justify-between">
                    <div class="h-8 w-8 bg-black rounded-sm"></div>
                    <div class="h-8 w-8 bg-zinc-100 rounded-sm"></div>
                </div>
            </div>
        </div>
    </div>
</section>
