---
import { Logo } from "../Logo";
import {
    getLangFromUrl,
    useTranslations,
    getLocalizedPath,
} from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="bg-border text-white py-20 px-8 text-center md:text-left">
    <div class="mx-auto max-w-7xl grid grid-cols-1 md:grid-cols-3 gap-16">
        <div class="space-y-6">
            <Logo lang={lang} />
            <p class="font-bold text-zinc-400">
                {t("footer.tagline")}
            </p>
        </div>
        <div class="space-y-4">
            <h4 class="font-heading text-main uppercase">
                {t("footer.links")}
            </h4>
            <ul class="space-y-2 font-bold uppercase text-sm">
                <li>
                    <a href="#pricing" class="hover:text-main"
                        >{t("nav.pricing")}</a
                    >
                </li>
                <li><a href="#" class="hover:text-main">{t("nav.demo")}</a></li>
                <li>
                    <a href="#" class="hover:text-main">{t("nav.resources")}</a>
                </li>
                <li>
                    <a href="#" class="hover:text-main">{t("nav.login")}</a>
                </li>
            </ul>
        </div>
        <div class="space-y-4">
            <h4 class="font-heading text-main uppercase">
                {t("footer.newsletter")}
            </h4>
            <div
                class="flex border-2 border-white rounded-base overflow-hidden"
            >
                <input
                    type="text"
                    placeholder={t("footer.emailPlaceholder")}
                    class="bg-transparent px-4 py-2 w-full outline-none font-bold placeholder:text-zinc-600"
                />
                <button class="bg-white text-black px-4 font-heading uppercase"
                    >{t("footer.join")}</button
                >
            </div>
        </div>
    </div>
    <div
        class="mx-auto max-w-7xl mt-20 pt-8 border-t border-zinc-800 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] font-heading uppercase tracking-[0.2em] text-zinc-500"
    >
        <span
            >&copy; {new Date().getFullYear()} Techveda ApS. {
                t("footer.rights")
            }</span
        >
        <div class="flex gap-8">
            <a href={getLocalizedPath("/privacy", lang)}
                >{t("footer.privacy")}</a
            >
            <a href={getLocalizedPath("/cookies", lang)}
                >{t("footer.cookies")}</a
            >
        </div>
    </div>
</footer>
